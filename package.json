{
  "name": "mantle-distribution-friction-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Track 2 research agent for Mantle Research Challenge — scores RWA distribution health and compliance friction",
  "scripts": {
    "score": "tsx scripts/score.ts",
    "score:spcxx": "tsx scripts/score.ts --asset spcxx",
    "score:tslax": "tsx scripts/score.ts --asset tslax",
    "dev": "concurrently -n api,web -c cyan,magenta \"tsx watch server/index.ts\" \"vite --config web/vite.config.ts\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "vite build --config web/vite.config.ts",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "preview": "npm run build && npm run start"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "overrides": {
    "shell-quote": "1.8.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}
